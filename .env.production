VITE_AUTH_SERVICE_URL=https://auth.botamation.in
VITE_AUTH_BACKEND_URL=https://auth.botamation.in

# Backend API configuration
# VITE_API_HOST and VITE_API_PORT are intentionally left empty so that
# axios uses relative paths (same-origin). The reverse proxy (Nginx)
# routes /api/* to the backend. VITE_API_TARGET is only used by the
# Vite dev proxy and has no effect in production builds.
VITE_API_HOST=
VITE_API_PORT=
VITE_API_TARGET=https://leads.botamation.in

# Current service URL (where this app is hosted — used for SSO redirect)
VITE_CURRENT_SERVICE_URL=https://leads.botamation.in

VITE_COOKIE_DOMAIN=.botamation.in
VITE_BRAND_NAME=Botamation
VITE_BRAND_LOGO_URL=https://data.botamation.ai/logo/botamation/Botamation%20Logo/black/BOTAMATION_white_on_black.svg
VITE_BRAND_FAVICON_URL=https://data.botamation.ai/logo/botamation/Botamation%20Logo/white/BOTAMATION.ico